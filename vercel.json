{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        },
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4"
        }
    ],
    "headers": [
        {
            "source": "/storage/(.*)\\.webp",
            "headers": [{ "key": "Content-Type", "value": "image/webp" }]
        },
        {
            "source": "/storage/(.*)\\.jpg",
            "headers": [{ "key": "Content-Type", "value": "image/jpeg" }]
        },
        {
            "source": "/storage/(.*)\\.svg",
            "headers": [{ "key": "Content-Type", "value": "image/svg+xml" }]
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(css|js|images|favicon\\.ico|robots\\.txt)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array"
    }
}
